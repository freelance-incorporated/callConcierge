generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  QUEUING  
  QUEUED   
  FAILED   
  COMPLETED
}

model Task {
  id             String     @id @default(uuid())
  userPhone      String     
  userName       String?    // ? means optional
  recipientPhone String     
  recipientName  String?
  instruction    String     
  userData       Json?  
  status         TaskStatus @default(QUEUING)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}